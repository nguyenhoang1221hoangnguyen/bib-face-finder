# App 1 — Indexer. Sao chép thành .env và điền giá trị. KHÔNG commit .env.

# ===== Google Drive =====
# ID folder Drive chứa ảnh (lấy từ URL folder).
DRIVE_FOLDER_ID=
# Đường dẫn file JSON khoá service account.
# - BẮT BUỘC khi chạy local/headless (folder phải được share cho email service account).
# - KHÔNG cần khi chạy Colab — notebook dùng `google.colab.auth` để xác thực OAuth user.
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# ===== Đầu ra index =====
INDEX_OUTPUT_DIR=data/index

# ===== Model khuôn mặt =====
FACE_MODEL=buffalo_l
FACE_DET_SIZE=640
FACE_CTX_ID=0          # GPU = 0, CPU = -1
FACE_MIN_DET_SCORE=0.5

# ===== OCR số BIB =====
ENABLE_BIB=true
BIB_LANG=en
BIB_MIN_CONF=0.6
BIB_MIN_LEN=2
BIB_MAX_LEN=6

# ===== Phát hiện vùng BIB (YOLO) — tăng độ chính xác OCR =====
BIB_USE_DETECTOR=true           # false = OCR toàn ảnh như cũ
BIB_DETECTOR_WEIGHTS=yolov8n.pt # mặc định: model phát hiện người (tự tải)
BIB_DETECTOR_CONF=0.25
BIB_DETECTOR_IS_CUSTOM=false     # true nếu dùng model YOLO tự train phát hiện trực tiếp bib
